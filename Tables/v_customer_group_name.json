    "CreateViewSql": " SELECT customer_id AS \"顧客ID\",\n    string_agg((group_name)::text, ','::text ORDER BY group_type_id, (group_name)::text) AS \"グループ名s\",\n    active_flg AS \"有効フラグ\"\n   FROM ( SELECT a.customer_id,\n            b.group_name,\n            b.group_type_id,\n            a.active_flg\n           FROM (m_customer_group a\n             JOIN m_group b ON ((a.group_id = b.group_id)))) main\n  GROUP BY customer_id, active_flg;",
