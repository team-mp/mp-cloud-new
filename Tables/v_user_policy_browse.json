  "ExternalDatabaseInfo": {
    "DataBaseType": "6db454c0-531c-4395-9122-921a18942902",
    "ConnectionId": "PostgreSQL1",
    "SourceTableName": "v_user_policy_browse",
    "SourceTableSchema": "public",
    "CreateViewSql": " SELECT u.user_id AS \"ユーザーID\",\n    n.policy_id AS \"運用規定ID\",\n    COALESCE(h.cnt, (0)::bigint) AS \"閲覧数\"\n   FROM ((m_user u\n     CROSS JOIN t_policy n)\n     LEFT JOIN ( SELECT t_policy_browse_history.browse_user_id,\n            t_policy_browse_history.policy_id,\n            count(*) AS cnt\n           FROM t_policy_browse_history\n          GROUP BY t_policy_browse_history.browse_user_id, t_policy_browse_history.policy_id) h ON (((u.user_id = h.browse_user_id) AND (n.policy_id = h.policy_id))))\n  WHERE (u.active_flg = 1);",
    "ViewInfo": {
      "ViewName": "v_user_policy_browse",
      "IsUpdatable": true,
