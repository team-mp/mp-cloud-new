    "SourceTableName": "v_billing_no_duplication",
    "SourceTableSchema": "public",
    "CreateViewSql": " SELECT DISTINCT main.billing_no AS \"請求番号\",\n    sub.billing_date AS \"請求日\",\n    sub.billing_name AS \"請求先名\"\n   FROM (( SELECT b.billing_no\n           FROM ( SELECT DISTINCT a.billing_no,\n                    a.billing_comp_id\n                   FROM t_sales a\n                  WHERE (a.delete_flg = 0)) b\n          GROUP BY b.billing_no\n         HAVING (count(b.billing_comp_id) > 1)) main\n     JOIN t_sales sub ON (((main.billing_no)::text = (sub.billing_no)::text)));",
