  "ExternalDatabaseInfo": {
    "DataBaseType": "6db454c0-531c-4395-9122-921a18942902",
    "AllowModifySchema": true,
    "ConnectionId": "PostgreSQL1",
    "SourceTableName": "v_customer_product",
    "SourceTableSchema": "public",
    "CreateViewSql": " SELECT main.\"顧客ID\",\n    main.\"グループID\",\n    main.\"申込タイプID\",\n    main.\"商品ID\",\n    main.\"申込区分\",\n    COALESCE(subc.original_product_name, main.\"商品名\") AS \"商品名\",\n    COALESCE(subc.original_billing_product_name, main.\"請求品名\") AS \"請求品名\",\n    COALESCE(subc.original_special_note, main.\"商品注釈\") AS \"商品注釈\",\n    COALESCE(subc.special_price, main.\"販売単価\") AS \"販売単価\",\n        CASE\n            WHEN (subc.special_price IS NOT NULL) THEN 1\n            ELSE 0\n        END AS \"特別販売単価フラグ\",\n    COALESCE(subc.special_survey_price, main.\"調査単価\") AS \"調査単価\",\n        CASE\n            WHEN (subc.special_survey_price IS NOT NULL) THEN 1\n            ELSE 0\n        END AS \"特別調査単価フラグ\",\n    COALESCE(subc.special_analysis_price, main.\"解析単価\") AS \"解析単価\",\n        CASE\n            WHEN (subc.special_analysis_price IS NOT NULL) THEN 1\n            ELSE 0\n        END AS \"特別解析単価フラグ\",\n    COALESCE(subc.special_gurantee_price, main.\"保証単価\") AS \"保証単価\",\n        CASE\n            WHEN (subc.special_gurantee_price IS NOT NULL) THEN 1\n            ELSE 0\n        END AS \"特別保証単価フラグ\",\n    COALESCE(subc.special_impjudge_gurantee_price, main.\"改良判定保証単価\") AS \"改良判定保証単価\",\n        CASE\n            WHEN (subc.special_impjudge_gurantee_price IS NOT NULL) THEN 1\n            ELSE 0\n        END AS \"特別改良判定保証単価フラグ\",\n    COALESCE(subc.special_base_price, main.\"基礎単価\") AS \"基礎単価\",\n        CASE\n            WHEN (subc.special_base_price IS NOT NULL) THEN 1\n            ELSE 0\n        END AS \"特別基礎単価フラグ\",\n    main.\"販売単価\" AS \"グループ標準単価\",\n    main.\"調査単価\" AS \"グループ標準調査単価\",\n    main.\"保証単価\" AS \"グループ標準保証単価\",\n    main.\"基礎単価\" AS \"グループ標準基礎単価\",\n    main.\"並び順\",\n    COALESCE(subd.product_public_flg, main.\"商品公開フラグ\") AS \"商品公開フラグ\",\n        CASE\n            WHEN (main.\"有効フラグ\" = 0) THEN 0\n            WHEN (subc.active_flg = 0) THEN 0\n            ELSE 1\n        END AS \"有効フラグ\"\n   FROM ((( SELECT main_1.customer_id AS \"顧客ID\",\n            sub.\"グループID\",\n            sub.\"申込タイプID\",\n            sub.\"申込区分\",\n            sub.\"商品ID\",\n            sub.\"商品名\",\n            sub.\"請求品名\",\n            sub.\"商品注釈\",\n            sub.\"販売単価\",\n            sub.\"特別販売単価フラグ\",\n            sub.\"調査単価\",\n            sub.\"特別調査単価フラグ\",\n            sub.\"解析単価\",\n            sub.\"特別解析単価フラグ\",\n            sub.\"保証単価\",\n            sub.\"特別保証単価フラグ\",\n            sub.\"改良判定保証単価\",\n            sub.\"特別改良判定保証単価フラグ\",\n            sub.\"基礎単価\",\n            sub.\"特別基礎単価フラグ\",\n            sub.\"標準単価\",\n            sub.\"標準調査単価\",\n            sub.\"標準保証単価\",\n            sub.\"標準基礎単価\",\n            sub.\"商品公開フラグ\",\n            sub.\"並び順\",\n            sub.\"有効フラグ\"\n           FROM (m_customer_group main_1\n             JOIN v_group_product sub ON ((main_1.group_id = sub.\"グループID\")))) main\n     LEFT JOIN m_customer_product subc ON (((main.\"顧客ID\" = subc.customer_id) AND (main.\"グループID\" = subc.group_id) AND (main.\"申込タイプID\" = subc.ordertype_id) AND (main.\"商品ID\" = subc.product_id))))\n     LEFT JOIN m_customer_product_public subd ON (((main.\"顧客ID\" = subd.customer_id) AND (main.\"グループID\" = subd.group_id) AND (main.\"申込タイプID\" = subd.order_type_id) AND (main.\"商品ID\" = subd.product_id))));",
    "UserSetQueryColumns": [
      "顧客ID",
      "グループID",
      "申込タイプID",
      "商品ID"
    ],
