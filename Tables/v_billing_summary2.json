  "ExternalDatabaseInfo": {
    "DataBaseType": "6db454c0-531c-4395-9122-921a18942902",
    "AllowModifySchema": true,
    "ConnectionId": "PostgreSQL1",
    "SourceTableName": "v_billing_summary2",
    "SourceTableSchema": "public",
    "CreateViewSql": " SELECT a.billing_no AS \"請求番号\",\n    a.billing_comp_id AS \"請求先ID\",\n    a.billing_name AS \"請求先名\",\n    a.billing_date AS \"請求日\",\n    a.invoice_issue_unit_id AS \"請求書発行単位ID\",\n    a.billing_send_way AS \"請求書送付方法\",\n    c.invoice_comment AS \"請求コメント\",\n    sum(a.excluding_tax_amount) AS \"請求合計\",\n    min(b.mail_send_flg) AS \"最小メール送信フラグ\",\n    min(b.mail_send_date) AS \"最小メール送信日\",\n    min(b.invoice_mailing_flg) AS \"最小請求書郵送フラグ\",\n    min(b.invoice_mailing_date) AS \"最小請求書郵送日\",\n    min(b.fax_send_flg) AS \"最小FAX送信フラグ\",\n    min(b.fax_send_date) AS \"最小FAX送信日\",\n    min(b.system_entry_flg) AS \"最小システム登録フラグ\",\n    min(b.system_entry_date) AS \"最小システム登録日\",\n    min(b.pdf_save_flg) AS \"最小PDF保存フラグ\",\n    min(b.pdf_save_date) AS \"最小PDF保存日\",\n    c.no_billing_processed_flg AS \"非請求処理済みフラグ\"\n   FROM ((t_sales a\n     JOIN t_sales_ext b ON ((a.sales_ext_id = b.sales_ext_id)))\n     LEFT JOIN m_billing_numbering c ON (((a.billing_no)::text = (c.billing_no)::text)))\n  WHERE (a.delete_flg = 0)\n  GROUP BY a.billing_no, a.billing_comp_id, a.billing_name, a.billing_date, a.invoice_issue_unit_id, a.billing_send_way, c.invoice_comment, c.no_billing_processed_flg;",
    "ViewInfo": {
      "ViewName": "v_billing_summary2",
      "QueryColumns": [
        "請求番号",
        "請求先ID",
        "請求先名",
        "請求日",
        "請求書発行単位ID",
        "請求書送付方法"
      ]
    }
  },
