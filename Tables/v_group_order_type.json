    "CreateViewSql": " SELECT main.group_id AS \"グループID\",\n    main.order_type_id AS \"申込タイプID\",\n    main.default_set_flg AS \"初期セットフラグ\",\n    main.order_type_public_flg AS \"申込タイプ公開フラグ\",\n        CASE\n            WHEN (main.special_note IS NOT NULL) THEN main.special_note\n            ELSE sub.special_note\n        END AS \"特記事項\",\n    sub.active_flg AS \"有効フラグ\"\n   FROM (m_group_order_type main\n     JOIN m_order_type sub ON ((main.order_type_id = sub.order_type_id)));",
