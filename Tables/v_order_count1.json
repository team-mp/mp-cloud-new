    "SourceTableSchema": "public",
    "CreateViewSql": " SELECT a.order_year_month AS \"申込年月\",\n    a.group_type_id AS \"グループ区分\",\n    count(a.object_order_id) AS \"レコード件数\"\n   FROM (t_object_order a\n     JOIN m_product b ON ((b.product_id = a.order_product_id)))\n  WHERE ((a.active_flg = 1) AND (b.public_product_flg = 1))\n  GROUP BY a.order_year_month, a.group_type_id;",
