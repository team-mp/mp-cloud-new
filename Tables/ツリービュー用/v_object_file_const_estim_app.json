    "SourceTableName": "v_object_file_const_estim_app",
    "SourceTableSchema": "public",
    "CreateViewSql": " SELECT a.object_id AS \"物件ID\",\n    a.parent_object_id AS \"親物件ID\",\n    c.file_class_id AS \"ファイル分類ID\",\n    b.file_attribute_id AS \"ファイル属性ID\",\n    ((((a.object_id || '_'::text) || c.file_class_id) || '_'::text) || b.file_attribute_id) AS \"ファイル属性キー\",\n    ((((((a.object_id || '_'::text) || c.file_class_id) || '_'::text) || b.file_attribute_id) || '_'::text) || d.construction_estimate_id) AS \"工事見積キー\",\n    d.construction_estimate_id AS \"工事見積ID\",\n    ((((e.customer_abbr)::text || '…('::text) || count(b.attachment_id)) || ')'::text) AS \"工事会社名\"\n   FROM ((((t_object_attachment_relation a\n     JOIN t_object_attachment b ON (((a.attachment_id = b.attachment_id) AND (b.active_flg = 1) AND (b.publish_flg = 1) AND (b.hidden_flg = 0))))\n     JOIN m_file_attribute c ON (((b.file_attribute_id = c.file_attribute_id) AND (c.applicant_company_authority > 0))))\n     JOIN t_object_construction_estimate d ON ((b.construction_estimate_id = d.construction_estimate_id)))\n     JOIN m_customer e ON ((d.construction_customer_id = e.customer_id)))\n  GROUP BY a.object_id, a.parent_object_id, c.file_class_id, b.file_attribute_id, d.construction_estimate_id, e.customer_abbr\n  ORDER BY a.object_id, b.file_attribute_id, d.construction_estimate_id;",
    "ViewInfo": {
      "ViewName": "v_object_file_const_estim_app",
