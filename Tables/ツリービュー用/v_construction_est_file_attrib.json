    "SourceTableName": "v_construction_est_file_attrib",
    "SourceTableSchema": "public",
    "CreateViewSql": " SELECT ce.construction_estimate_id AS \"工事見積ID\",\n    f.file_class_id AS \"ファイル分類ID\",\n    f.file_attribute_id AS \"ファイル属性ID\",\n    ((((f.file_attribute_name)::text || '…('::text) || COALESCE(count(t.attachment_id), (0)::bigint)) || ')'::text) AS \"ファイル属性名\"\n   FROM (((t_object_construction_estimate ce\n     JOIN m_file_attribute f ON (true))\n     JOIN m_file_class fc ON (((f.file_class_id = fc.file_class_id) AND (fc.construction_estimate_flg = 1))))\n     LEFT JOIN t_object_attachment t ON (((ce.construction_estimate_id = t.construction_estimate_id) AND (f.file_attribute_id = t.file_attribute_id) AND (t.active_flg = 1) AND (t.construction_estimate_id IS NOT NULL))))\n  GROUP BY ce.construction_estimate_id, f.file_class_id, f.file_attribute_id, f.file_attribute_name;",
