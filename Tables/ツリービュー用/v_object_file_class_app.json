    "SourceTableName": "v_object_file_class_app",
    "SourceTableSchema": "public",
    "CreateViewSql": " SELECT a.object_id AS \"物件ID\",\n    a.parent_object_id AS \"親物件ID\",\n    c.file_class_id AS \"ファイル分類ID\",\n    ((a.object_id || '_'::text) || c.file_class_id) AS \"ファイル分類キー\"\n   FROM ((t_object_attachment_relation a\n     JOIN t_object_attachment b ON (((a.attachment_id = b.attachment_id) AND (b.active_flg = 1) AND (b.publish_flg = 1) AND (b.hidden_flg = 0))))\n     JOIN m_file_attribute c ON (((b.file_attribute_id = c.file_attribute_id) AND (c.applicant_company_authority > 0))))\n  GROUP BY a.object_id, a.parent_object_id, c.file_class_id\n  ORDER BY a.object_id, c.file_class_id;",
