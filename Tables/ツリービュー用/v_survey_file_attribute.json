  "ExternalDatabaseInfo": {
    "DataBaseType": "6db454c0-531c-4395-9122-921a18942902",
    "AllowModifySchema": true,
    "ConnectionId": "PostgreSQL1",
    "SourceTableName": "v_survey_file_attribute",
    "SourceTableSchema": "public",
    "CreateViewSql": " SELECT s.survey_id AS \"調査ID\",\n    f.file_class_id AS \"ファイル分類ID\",\n    f.file_attribute_id AS \"ファイル属性ID\",\n    concat(f.file_attribute_name, '…(', COALESCE(count(t.attachment_id), (0)::bigint), ')') AS \"ファイル属性名\"\n   FROM (((t_object_survey s\n     JOIN m_file_attribute f ON (true))\n     JOIN m_file_class c ON (((f.file_class_id = c.file_class_id) AND (c.survey_flg = 1))))\n     LEFT JOIN t_object_attachment t ON (((s.survey_id = t.survey_id) AND (f.file_attribute_id = t.file_attribute_id) AND (t.active_flg = 1) AND (t.survey_id IS NOT NULL))))\n  GROUP BY s.survey_id, f.file_class_id, f.file_attribute_id, f.file_attribute_name;",
    "ViewInfo": {
      "ViewName": "v_survey_file_attribute",
