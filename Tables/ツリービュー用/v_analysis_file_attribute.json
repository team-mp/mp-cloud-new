    "SourceTableSchema": "public",
    "CreateViewSql": " SELECT a.analysis_id AS \"解析ID\",\n    f.file_class_id AS \"ファイル分類ID\",\n    f.file_attribute_id AS \"ファイル属性ID\",\n    ((((f.file_attribute_name)::text || '…('::text) || COALESCE(count(t.attachment_id), (0)::bigint)) || ')'::text) AS \"ファイル属性名\"\n   FROM (((t_object_analysis a\n     JOIN m_file_attribute f ON (true))\n     JOIN m_file_class c ON (((f.file_class_id = c.file_class_id) AND (c.analysis_flg = 1))))\n     LEFT JOIN t_object_attachment t ON (((a.analysis_id = t.analysis_id) AND (f.file_attribute_id = t.file_attribute_id) AND (t.active_flg = 1))))\n  GROUP BY a.analysis_id, f.file_class_id, f.file_attribute_id, f.file_attribute_name;",
