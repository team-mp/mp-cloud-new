    "SourceTableName": "v_billing_no_multiple_object",
    "SourceTableSchema": "public",
    "CreateViewSql": " SELECT billing_no AS \"請求番号\",\n    billing_name AS \"請求先名\",\n    billing_date AS \"請求日\",\n    count(object_id) AS \"重複物件数\"\n   FROM ( SELECT DISTINCT a.billing_no,\n            a.billing_name,\n            a.billing_date,\n            b.object_id\n           FROM (t_sales a\n             JOIN t_object_order b ON ((a.object_order_id = b.object_order_id)))\n          WHERE ((a.invoice_issue_unit_id = 2) AND (a.delete_flg = 0))) main\n  GROUP BY billing_no, billing_name, billing_date\n HAVING (count(object_id) > 1);",
