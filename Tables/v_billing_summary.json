  "ExternalDatabaseInfo": {
    "DataBaseType": "6db454c0-531c-4395-9122-921a18942902",
    "AllowModifySchema": true,
    "ConnectionId": "PostgreSQL1",
    "SourceTableName": "v_billing_summary",
    "SourceTableSchema": "public",
    "CreateViewSql": " SELECT a.billing_no AS \"請求番号\",\n    a.billing_comp_id AS \"請求先ID\",\n    a.billing_name AS \"請求先名\",\n    a.billing_date AS \"請求日\",\n    d.invoice_comment AS \"請求コメント\",\n    a.collect_scheduled_date AS \"回収予定日\",\n    b.sales_staff_id AS \"営業担当ID\",\n    sum(a.excluding_tax_amount) AS \"請求合計\"\n   FROM (((t_sales a\n     JOIN m_customer b ON ((a.billing_comp_id = b.customer_id)))\n     JOIN t_sales_ext c ON ((a.sales_ext_id = c.sales_ext_id)))\n     LEFT JOIN m_billing_numbering d ON (((a.billing_no)::text = (d.billing_no)::text)))\n  WHERE (a.delete_flg = 0)\n  GROUP BY a.billing_no, a.billing_comp_id, a.billing_name, a.billing_date, d.invoice_comment, a.collect_scheduled_date, b.sales_staff_id;",
