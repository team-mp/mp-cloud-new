    "SourceTableName": "v_customer_ground_pressure",
    "SourceTableSchema": "public",
    "CreateViewSql": " SELECT main.customer_id AS \"顧客ID\",\n    main.ground_pressure_id AS \"設計接地圧ID\",\n    main.sutructure_id AS \"建物構造ID\",\n    main.foundastion_id AS \"基礎形状ID\",\n        CASE\n            WHEN (sub.ground_pressure IS NOT NULL) THEN sub.ground_pressure\n            ELSE main.ground_pressure\n        END AS \"設計接地圧\",\n    main.default_flg AS \"既定フラグ\"\n   FROM (( SELECT a.customer_id,\n            b.ground_pressure_id,\n            b.sutructure_id,\n            b.foundastion_id,\n            b.ground_pressure,\n            b.default_flg\n           FROM (m_customer a\n             JOIN m_ground_pressure b ON (true))) main\n     LEFT JOIN m_customer_ground_pressure sub ON (((sub.customer_id = main.customer_id) AND (sub.ground_pressure_id = main.ground_pressure_id))));",
    "UserSetQueryColumns": [
      "顧客ID",
